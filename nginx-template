server {
        listen 80;
        server_name networkv1.getsession.org;

        client_max_body_size 10M;

        location / {
                include /etc/nginx/uwsgi_params;
                uwsgi_pass unix:///home/network-api/api/network-api.wsgi;
        }

        access_log /var/log/nginx/networkv1.getsession.org.access.log;
        error_log  /var/log/nginx/networkv1.getsession.org.log;
}

server {
        listen 443 ssl;
        server_name networkv1.getsession.org;

        ssl_certificate     /etc/letsencrypt/live/networkv1.getsession.org/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/networkv1.getsession.org/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;
        ssl_ciphers         HIGH:!aNULL:!MD5;

        client_max_body_size 10M;

        location / {
                include /etc/nginx/uwsgi_params;
                uwsgi_pass unix:///home/network-api/api/network-api.wsgi;
        }

        access_log /var/log/nginx/networkv1.getsession.org.access.log;
        error_log  /var/log/nginx/networkv1.getsession.org.log;
}
